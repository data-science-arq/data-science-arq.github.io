rm(list = ls(all.names = TRUE))
library(pwr)
#===============
# Q1
main_effects_power <- function(n, k, f2, alpha = 0.05) {
# # Whole-model F-test! not
u <- k
v <- n - k - 1
if (u <= 0 || v <= 0) return(NA_real_)
pwr.f2.test(u = u, v = v, f2 = f2, sig.level = alpha)$power
}
# medium effect
main_effects_power(n=92, k=5, f2=0.15)
main_effects_power(n = 83, k = 4, f2 = 0.15)
main_effects_power(n = 83, k = 4, f2 = 0.14)
main_effects_power(n = 83, k = 4, f2 = 0.16)
main_effects_power(n = 83, k = 5, f2 = 0.15)
main_effects_power(n = 83, k = 5, f2 = 0.17)
main_effects_power(n = 83, k = 5, f2 = 0.16)
pwr.f2.test(u = 4, v = 83-4-1, f2 = 0.15, sig.level = 0.05)$power
pwr.f2.test(u = 4, v = 83-4-1, f2 = 0.15, sig.level = 0.05)
pwr.f2.test(u = 5, v = 83-5-1, f2 = 0.15, sig.level = 0.05)
pwr.f2.test(u = 5, v = 83-5-1, f2 = 0.16, sig.level = 0.05)
